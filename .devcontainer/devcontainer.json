{
  "name": "Flask Backend",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "postCreateCommand": "pip install -r requirements.txt",
  "forwardPorts": [8587],
  "portsAttributes": {
    "8587": {
      "label": "Flask Backend",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "qwtel.sqlite-viewer",
        "humao.rest-client"
      ]
    }
  }
}
